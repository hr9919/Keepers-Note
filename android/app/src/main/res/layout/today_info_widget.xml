<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="14dp"
    android:background="@drawable/bg_widget_weather_sunny">

    <LinearLayout
        android:id="@+id/top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="키퍼노트"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#CCFFFFFF"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/widget_refresh_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="↻"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/bg_widget_icon_button"
            android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/main_weather"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_row"
        android:layout_alignParentStart="true"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_weather_icon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:gravity="center"
            android:text="☀️"
            android:textSize="34sp"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/widget_weather_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="맑음"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/hourly_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/main_weather"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        android:gravity="end">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_hourly_0_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06시"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/widget_hourly_0_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="☀️"
                android:textSize="14sp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_hourly_1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09시"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/widget_hourly_1_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="☁️"
                android:textSize="14sp"
                android:includeFontPadding="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_hourly_2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12시"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/widget_hourly_2_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="🌧️"
                android:textSize="14sp"
                android:includeFontPadding="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/resource_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:id="@+id/widget_fluorite_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="88dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="10dp"
            android:background="@drawable/bg_widget_info_card">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_fluorite_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_widget_fluorite"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/widget_fluorite_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="형광석"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#CCFFFFFF"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_fluorite_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textAlignment="center"
                android:text="4번 집 앞"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:includeFontPadding="false"
                android:maxLines="2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_oak_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:minHeight="88dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="10dp"
            android:background="@drawable/bg_widget_info_card">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_oak_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_widget_oak"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/widget_oak_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="참나무"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#CCFFFFFF"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_oak_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textAlignment="center"
                android:text="참나무 숲"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:includeFontPadding="false"
                android:maxLines="2" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>