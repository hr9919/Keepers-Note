<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFFFC6DA"
                android:centerColor="#FFFFE29A"
                android:endColor="#FFCDB4FF" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- 컬러 번짐 유지 -->
    <item
        android:left="150dp"
        android:top="102dp"
        android:right="-12dp"
        android:bottom="-6dp">
        <shape android:shape="oval">
            <solid android:color="#20B8F2E6" />
        </shape>
    </item>

</layer-list>