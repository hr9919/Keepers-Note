<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 기본 그라디언트 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF8ED8FF"
                android:centerColor="#FFBEE9FF"
                android:endColor="#FFEAF8FF" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- 우하단 번짐만 유지 -->
    <item
        android:left="170dp"
        android:top="150dp"
        android:right="-18dp"
        android:bottom="-8dp">
        <shape android:shape="oval">
            <solid android:color="#18FFFFFF" />
        </shape>
    </item>

</layer-list>